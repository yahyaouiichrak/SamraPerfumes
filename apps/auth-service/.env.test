# ======================
# TEST ENVIRONMENT VARIABLES
# ======================
NODE_ENV=test
PORT=4001
LOG_LEVEL=error
SERVICE_NAME=auth-service-test
VERSION=1.0.0

# ======================
# DATABASE (PostgreSQL Test) - Port 5433
# ======================
DB_HOST=localhost
DB_PORT=5433
DB_USER=test_user
DB_PASSWORD=test_password
DB_NAME=test_db

# ======================
# JWT TOKENS (Test secrets)
# ======================
JWT_SECRET=test-jwt-secret-key-minimum-32-characters-long-for-testing
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=test-refresh-secret-key-minimum-32-characters-long-testing
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# ADMIN REGISTRATION
# ======================
ADMIN_REGISTRATION_SECRET=test-admin-secret-key-for-testing

# ======================
# KAFKA (Mocked in tests)
# ======================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=auth-service-test
KAFKA_TOPIC_USER_EVENTS=user-events-test
KAFKA_TOPIC_AUTH_EVENTS=auth-events-test

# ======================
# REDIS (Mocked in tests)
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ======================
# EMAIL (Mocked in tests)
# ======================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Test Auth Service <test@example.com>

# ======================
# FRONTEND
# ======================
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ======================
# MONITORING
# ======================
METRICS_PORT=9101