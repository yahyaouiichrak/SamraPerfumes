{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Authentication microservice for Perfume Platform",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
"pretest": "cd ../.. && docker-compose -f docker-compose.dev.yml up -d postgres-test && cd apps/auth-service && node scripts/wait-for-postgres.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "posttest": "echo Tests completed.",
    
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --runInBand --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:unit": "cross-env NODE_ENV=test jest tests/unit --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration --runInBand --forceExit",
    
    "test:db:stop": "cd ../.. && docker-compose -f docker-compose.dev.yml stop postgres-test",
    "test:db:clean": "cd ../.. && docker-compose -f docker-compose.dev.yml down postgres-test -v",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\"",
    "migration:generate": "sequelize-cli migration:generate --name",
    "migration:run": "sequelize-cli db:migrate",
    "migration:undo": "sequelize-cli db:migrate:undo",
    "health": "node health-check.js",
    "db:test": "node test-db.js",
    "docker:up": "docker-compose -f ../../docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f ../../docker-compose.dev.yml down",
    "docker:restart": "docker-compose -f ../../docker-compose.dev.yml restart",
    "docker:logs": "docker-compose -f ../../docker-compose.dev.yml logs -f",
    "docker:ps": "docker-compose -f ../../docker-compose.dev.yml ps",
    "docker:clean": "docker-compose -f ../../docker-compose.dev.yml down -v",
    "kafka:topics": "docker exec -it perfume-kafka kafka-topics --list --bootstrap-server localhost:9092",
    "kafka:create": "docker exec -it perfume-kafka kafka-topics --create --bootstrap-server localhost:9092 --topic",
    "setup": "pnpm docker:up && sleep 10 && pnpm health"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.0",
    "rate-limit-redis": "^3.1.0",
    "sequelize": "^6.35.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "sequelize-cli": "^6.6.5",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}